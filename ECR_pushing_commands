#Before executing below commands, We need to install AWS CLI to talk with AWS API's.


#Command to connect with ECR 

aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 976193245035.dkr.ecr.ap-south-1.amazonaws.com

#Command to build the image 

docker build -t demo-ecr .

#Command to put tag on image

docker tag demo-ecr:latest 976193245035.dkr.ecr.ap-south-1.amazonaws.com/demo-ecr:latest

#Command to push the image onto ECR

docker push 976193245035.dkr.ecr.ap-south-1.amazonaws.com/demo-ecr:latest

